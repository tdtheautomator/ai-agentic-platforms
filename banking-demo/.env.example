# Banking Demo Environment Configuration
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────────────────────────
# LLM Configuration
# ─────────────────────────────────────────────────────────────────

# Ollama configuration (local LLM)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:0.6b

# Optional: OpenAI API key (if you want to use OpenAI instead of Ollama)
OPENAI_API_KEY=

# Optional: Anthropic API key (if you want to use Claude instead of Ollama)
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────
# Observability Configuration
# ─────────────────────────────────────────────────────────────────

# Slack webhook URL for alerts (optional)
# Get this from: https://api.slack.com/messaging/webhooks
# Format: https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_WEBHOOK_URL=

# Grafana credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ─────────────────────────────────────────────────────────────────
# Notes
# ─────────────────────────────────────────────────────────────────
#
# 1. SLACK_WEBHOOK_URL is optional. If not set, alerts will not be sent to Slack.
#    To enable Slack alerts:
#    - Create a Slack workspace and app
#    - Create an Incoming Webhook
#    - Copy the webhook URL and paste it here
#    - Create these channels in your Slack workspace:
#      * #banking-demo-critical
#      * #banking-demo-alerts
#      * #banking-demo-info
#
# 2. LLM Configuration:
#    - By default, uses local Ollama at http://host.docker.internal:11434
#    - If Ollama is not running, the app will fall back to mock mode
#    - To use OpenAI or Anthropic, set the respective API keys
#
# 3. Grafana:
#    - Access at http://localhost:3000
#    - Default credentials: admin / admin
#    - Change password after first login
#
