# E-Commerce Demo Environment Configuration
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────────────────────────
# LLM Configuration
# ─────────────────────────────────────────────────────────────────

# Ollama configuration (local LLM)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:0.6b

# Optional: Override model for e-commerce demo only
ECOMMERCE_OLLAMA_MODEL=

# Optional: OpenAI API key (if you want to use OpenAI instead of Ollama)
OPENAI_API_KEY=

# Optional: Anthropic API key (if you want to use Claude instead of Ollama)
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────
# Data Storage Configuration
# ─────────────────────────────────────────────────────────────────

# Data directory for ChromaDB and SQLite
DATA_DIR=/data

# ─────────────────────────────────────────────────────────────────
# Observability Configuration
# ─────────────────────────────────────────────────────────────────

# Slack webhook URL for alerts (optional)
# Get this from: https://api.slack.com/messaging/webhooks
# Format: https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_WEBHOOK_URL=

# Grafana credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ─────────────────────────────────────────────────────────────────
# Notes
# ─────────────────────────────────────────────────────────────────
#
# 1. LLM Configuration:
#    - By default, uses local Ollama at http://host.docker.internal:11434
#    - If Ollama is not running, the app will fall back to mock mode
#    - To use OpenAI or Anthropic, set the respective API keys
#    - Priority: OpenAI → Anthropic → Ollama → Mock
#
# 2. Supported Ollama Models:
#    - phi3:mini (2.2 GB) - fastest
#    - llama3.2 (2.0 GB) - balanced
#    - mistral (4.1 GB) - best quality
#    - qwen3:0.6b (default)
#
# 3. Data Storage:
#    - ChromaDB: /data/chroma (semantic memory)
#    - SQLite: /data/sqlite (episodic memory)
#    - Redis: External service (working memory)
#
# 4. Running the Demo:
#    # With Docker Compose
#    docker compose up --build
#
#    # Locally (requires Redis running)
#    python -m uvicorn main:app --reload --port 8007
#
# 5. Access Points:
#    - UI: http://localhost:8007
#    - API: http://localhost:8007/api/
#    - Docs: http://localhost:8007/docs
#
