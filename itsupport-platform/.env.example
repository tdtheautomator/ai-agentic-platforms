# ─────────────────────────────────────────────────────────────────────────────
#  Agent Demo — Environment Variables
#  Copy to .env and edit. All demos run with Ollama by default.
#  API keys are optional — only set if you want cloud LLM responses.
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloud API keys (optional — leave blank to use Ollama) ────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Ollama settings ───────────────────────────────────────────────────────────
# Host (default works on Windows/Mac; Linux uses host-gateway in compose)
OLLAMA_HOST=http://host.docker.internal:11434

# Global default model — used by all services unless overridden below
OLLAMA_MODEL=qwen3:0.6b
